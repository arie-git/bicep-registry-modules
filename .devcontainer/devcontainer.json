{
  "name": "Ubuntu",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20-bullseye",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-github-actions",
        "GitHub.vscode-pull-request-github",
        "microsoft-dciborow.align-bicep",
        "ms-azuretools.vscode-bicep",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-azuretools.vscode-azure-github-copilot",
        "ms-vsliveshare.vsliveshare",
        "zokugun.explicit-folding"
      ]
    }
  },
  "postCreateCommand": "claude plugin marketplace add microsoft/azure-skills && claude plugin install azure@azure-skills",
  "postStartCommand": "sudo chmod -R g+w /usr/local/share/npm-global/lib/node_modules/@anthropic-ai 2>/dev/null || true && claude plugin update azure https://github.com/microsoft/azure-skills 2>/dev/null || true",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/node/.dotnet/tools:/home/node/.azure/bin"
  },
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest",
      "installBicep": true
    },
    "ghcr.io/devcontainers/features/dotnet:2": {},
    "ghcr.io/devcontainers/features/powershell:1": {
      "modules": ["Az.Accounts", "Az.Resources", "Az.KeyVault", "Pester"]
    },
    "ghcr.io/devcontainers-extra/features/prettier:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/act-asdf:2": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  }
}

{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-aps-04 - Deny lower / legacy TLS versions'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+App+Service#IncidentremediationAppService#drcp-aps-04 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP App Service Site Minimum TLS version",
    "description": "This policy prevents the creation of an app service (such as an Web App, Function App or Logic App v2) that has configured a TLS version lower then required.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "App Service",
        "name": "AppServiceSiteMinimumTlsVersion",
        "severity": 3,
        "controlId": "drcp-aps-04",
        "controlDesc": "Deny lower / legacy TLS versions",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+App+Service",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+App+Service#IncidentremediationAppService-drcp-aps-04"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "minimumTlsVersion": {
        "type": "String",
        "metadata": {
          "displayName": "Minimum TLS Version",
          "description": "Minimum version of TLS required to access the app service"
        },
        "allowedValues": [
          "1.2",
          "1.3"
        ],
        "defaultValue": "1.2"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites"
          },
          {
            "field": "Microsoft.Web/sites/siteConfig.minTlsVersion",
            "exists": "true"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Web/sites/siteConfig.minTlsVersion",
                "less": "[parameters('minimumTlsVersion')]"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-amo-03 - Restrict destination Log Analytics Workspace'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Azure+Monitor#IncidentremediationAzureMonitor-drcp-amo-03 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Azure Monitor Data Collection Rule Destination Log Analytics Workspace",
    "mode": "All",
    "description": "This policy denies the use of destination Log Analytics Workspaces that reside outside of the current subscription.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Monitor",
        "name": "MonitorDataCollectionRulesDestinationLAW",
        "severity": 3,
        "controlId": "drcp-amo-03",
        "controlDesc": "Azure Monitor Data Collection Rules: Restrict destination Log Analytics Workspace",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Azure+Monitor",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Azure+Monitor#IncidentremediationAzureMonitor-drcp-amo-03"
      }
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "allowedSubscriptionIds": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed subscription IDs",
          "description": "Array of subscriptions IDs that are allowed access."
        },
        "defaultValue": []
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Insights/dataCollectionRules"
          },
          {
            "allOf": [
              {
                "count": {
                  "field": "Microsoft.Insights/dataCollectionRules/destinations.logAnalytics[*]",
                  "where": {
                    "value": "[split(current('Microsoft.Insights/dataCollectionRules/destinations.logAnalytics[*].workspaceResourceId'), '/')[2]]",
                    "notIn": "[parameters('allowedSubscriptionIds')]"
                  }
                },
                "greater": 0
              },
              {
                "value": "[length(field('Microsoft.Insights/dataCollectionRules/destinations.logAnalytics'))]",
                "greater": 0
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
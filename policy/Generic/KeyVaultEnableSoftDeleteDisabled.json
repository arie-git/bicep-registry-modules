{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-kv-05 - Soft delete in Key Management in Azure Key Vault'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Key+Vault#IncidentremediationKeyVault#drcp-kv-05 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP KeyVault Disabled soft delete",
    "description": "This policy prevents the creation of a Key vault when soft delete is not enabled. Deleting a key vault without soft delete enabled permanently deletes all secrets, keys, and certificates stored in the key vault. Accidental deletion of a key vault can lead to permanent data loss. Soft delete allows you to recover an accidentally deleted key vault for a configurable retention period.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Key Vault",
        "name": "KeyVaultEnableSoftDeleteDisabled",
        "severity": 3,
        "controlId": "drcp-kv-05",
        "controlDesc": "Soft delete in key management in Azure Key Vault",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Key+Vault",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Key+Vault#IncidentremediationKeyVault-drcp-kv-05"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.KeyVault/vaults"
          },
          {
            "not": {
              "field": "Microsoft.KeyVault/vaults/createMode",
              "equals": "recover"
            }
          },
          {
            "anyOf": [
              {
                "allOf": [
                  {
                    "value": "[requestContext().apiVersion]",
                    "less": "2019-09-01"
                  },
                  {
                    "anyOf": [
                      {
                        "field": "Microsoft.KeyVault/vaults/enableSoftDelete",
                        "equals": "false"
                      },
                      {
                        "field": "Microsoft.KeyVault/vaults/enableSoftDelete",
                        "exists": "false"
                      }
                    ]
                  }
                ]
              },
              {
                "allOf": [
                  {
                    "value": "[requestContext().apiVersion]",
                    "greaterOrEquals": "2019-09-01"
                  },
                  {
                    "field": "Microsoft.KeyVault/vaults/enableSoftDelete",
                    "equals": "false"
                  }
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

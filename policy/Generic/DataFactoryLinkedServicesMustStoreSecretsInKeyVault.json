{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-adf-04 - Restrict the exposure of credential and secrets'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Data+Factory#IncidentremediationDataFactory#drcp-adf-04 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Data Factory Linked service should store secrets in Azure KeyVault",
    "description": "This policy denies the creation of a Data Factory linked service that stores secrets (such as passwords, keys, tokens, certificates, etc.) internally in a Data Factory. It should use an Azure KeyVault instead.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Data Factory",
        "name": "DataFactoryLinkedServicesMustStoreSecretsInKeyVault",
        "severity": 3,
        "controlId": "drcp-adf-04",
        "controlDesc": "Restrict the exposure of credential and secrets",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Data+Factory",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Data+Factory#IncidentremediationDataFactory-drcp-adf-04"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.DataFactory/factories/linkedservices"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.DataFactory/factories/linkedservices/typeProperties.encryptedCredential",
                "exists": "true"
              },
              {
                "field": "Microsoft.DataFactory/factories/linkedservices/AmazonMWS.typeProperties.mwsAuthToken.type",
                "equals": "SecureString"
              },
              {
                "field": "Microsoft.DataFactory/factories/linkedservices/AmazonMWS.typeProperties.secretKey.type",
                "equals": "SecureString"
              },
              {

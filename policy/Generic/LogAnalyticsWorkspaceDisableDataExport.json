{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-log-02 - Data Export'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Log+Analytics+Workspace#IncidentremediationLogAnalyticsWorkspace#drcp-log-02 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Log Analytics Workspace Disable data exports",
    "description": "This policy disables data export rules from the Log Analytics Workspace.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Log Analytics Workspace",
        "name": "LogAnalyticsWorkspaceDisableDataExport",
        "severity": 3,
        "controlId": "drcp-log-02",
        "controlDesc": "Data export",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Log+Analytics+Workspace",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Log+Analytics#IncidentremediationLogAnalytics-drcp-log-02"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Deny, Disabled or Audit."
        },
        "allowedValues": [
          "Deny",
          "Disabled",
          "Audit"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.OperationalInsights/workspaces/dataExports"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.OperationalInsights/workspaces/dataExports/destination.resourceId",
                "notContains": "[subscription().id]"
              },
              {
                "field": "Microsoft.OperationalInsights/workspaces/dataExports/destination.resourceId",
                "notContains": "Microsoft.Storage/storageAccounts"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
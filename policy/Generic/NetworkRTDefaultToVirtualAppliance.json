{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-sub-02 - Default network route'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription#drcp-sub-02 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Network Default route to Virtual Appliance",
    "description": "DRCP - Adds route with address prefix 0.0.0.0/0 pointing to the virtual appliance in case there is none.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Subscription",
        "name": "NetworkRTDefaultToVirtualAppliance",
        "severity": 3,
        "controlId": "drcp-sub-02",
        "controlDesc": "Default network route",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Subscription",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription-drcp-sub-02"
      },
      "dynamic": "true"
    },
    "mode": "All",
    "parameters": {
      "virtualApplianceIpAddress": {
        "type": "String",
        "metadata": {
          "displayName": "NVA IP",
          "description": "IP address of the NVA."
        },
        "defaultValue": "10.250.4.254"
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Modify or Disabled."
        },
        "allowedValues": [
          "Modify",
          "Disabled"
        ],
        "defaultValue": "Modify"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Network/routeTables"
          },
          {
            "not": {
              "value": "[resourceGroup().name]",
              "like": "*-agw-rg"
            }
          },
          {
            "count": {
              "field": "Microsoft.Network/routeTables/routes[*]",
              "where": {
                "field": "Microsoft.Network/routeTables/routes[*].addressPrefix",
                "equals": "0.0.0.0/0"
              }
            },
            "equals": 0
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "roleDefinitionIds": [
            "/providers/microsoft.authorization/roleDefinitions/4d97b98b-1d4f-4787-a291-c67834d212e7"
          ],
          "conflictEffect": "audit",
          "operations": [
            {
              "operation": "add",
              "field": "Microsoft.Network/routeTables/routes[*]",
              "value": {
                "name": "default",
                "properties": {
                  "addressPrefix": "0.0.0.0/0",
                  "nextHopType": "VirtualAppliance",
                  "nextHopIpAddress": "[parameters('virtualApplianceIpAddress')]"
                }
              }
            }
          ]
        }
      }
    }
  }
}

{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-st-14 - Defender for Storage'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Storage+Account#IncidentremediationStorageAccount#drcp-st-14 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP StorageAccount Defender",
    "description": "This policy checks if Azure Defender for Azure Storage Accounts is enabled with Malware scanning and Sensitive data discovery disabled.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Storage Account",
        "name": "StorageAccountDefenderEnabledV2",
        "severity": 3,
        "controlId": "drcp-st-14",
        "controlDesc": "Microsoft Defender for Cloud",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Storage+Account",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Storage+Account#IncidentremediationStorageAccount-drcp-st-14"
      },
      "dynamic": "true"
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - AuditIfNotExists or Disabled."
        },
        "allowedValues": [
          "AuditIfNotExists",
          "Disabled"
        ],
        "defaultValue": "AuditIfNotExists"
      },
      "requiredSettings": {
        "type": "array",
        "metadata": {
          "description": "Which settings are required.'",
          "displayName": "Required settings"
        },
        "allowedValues": [
          "OnUploadMalwareScanning"
        ],
        "defaultValue": [
          "OnUploadMalwareScanning"
        ]
      },
      "notAllowedSettings": {
        "type": "array",
        "metadata": {
          "description": "Which settings to disallow.'",
          "displayName": "Disallowed settings"
        },
        "allowedValues": [
          "SensitiveDataDiscovery"
        ],
        "defaultValue": [
          "SensitiveDataDiscovery"
        ]
      }
    },
    "policyRule": {
      "if": {
        "field": "type",
        "equals": "Microsoft.Resources/subscriptions"
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "type": "Microsoft.Security/pricings",
          "name": "StorageAccounts",
          "evaluationDelay": "AfterProvisioning",
          "existenceScope": "subscription",
          "existenceCondition": {
            "allOf": [
              {
                "field": "Microsoft.Security/pricings/pricingTier",
                "equals": "Standard"
              },
              {
                "field": "Microsoft.Security/pricings/subPlan",
                "equals": "DefenderForStorageV2"
              },
              {
                "count": {
                  "field": "Microsoft.Security/pricings/extensions[*]",
                  "where": {
                    "allOf": [
                      {
                        "field": "Microsoft.Security/pricings/extensions[*].name",
                        "in": "[parameters('requiredSettings')]"
                      },
                      {
                        "field": "Microsoft.Security/pricings/extensions[*].isEnabled",
                        "equals": "true"
                      }
                    ]
                  }
                },
                "equals": 1
              },
              {
                "count": {
                  "field": "Microsoft.Security/pricings/extensions[*]",
                  "where": {
                    "allOf": [
                      {
                        "field": "Microsoft.Security/pricings/extensions[*].name",
                        "in": "[parameters('notAllowedSettings')]"
                      },
                      {
                        "field": "Microsoft.Security/pricings/extensions[*].isEnabled",
                        "equals": "false"
                      }
                    ]
                  }
                },
                "equals": 1
              }
            ]
          }
        }
      }
    }
  }
}

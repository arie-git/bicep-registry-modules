{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-sub-07 - Cross subscription private links'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription#drcp-sub-07 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP SQL Servers Network Inbound Private endpoints private link service connections",
    "description": "This policy prevents inbound private link(s) between external subscriptions and SQL Server.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "SQL Database",
        "name": "SQLServerPEPLServiceConnections_Inbound",
        "severity": 3,
        "controlId": "drcp-sub-07",
        "controlDesc": "Cross Subscription private links",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Subscription",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription#drcp-sub-07"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Deny or Disabled."
        },
        "allowedValues": [
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "allowedInboundPrivateLinkServices": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed external subscriptions",
          "description": "List of the subscription ids."
        },
        "defaultValue": [
          "subscription().subscriptionId"
        ]
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Sql/servers/privateEndpointConnections"
          },
          {
            "field": "Microsoft.Sql/servers/privateEndpointConnections/privateLinkServiceConnectionState.status",
            "equals": "Approved"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Sql/servers/privateEndpointConnections/privateEndpoint.id",
                "exists": false
              },
              {
                "value": "[split(concat(field('Microsoft.Sql/servers/privateEndpointConnections/privateEndpoint.id'), '//'), '/')[2]]",
                "notIn": "[parameters('allowedInboundPrivateLinkServices')]"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

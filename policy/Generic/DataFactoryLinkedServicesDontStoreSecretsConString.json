{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-adf-04 - Restrict the exposure of credential and secrets'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Data+Factory#IncidentremediationDataFactory#drcp-adf-04 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Data Factory Linked service should not store secrets in connection strings",
    "description": "This policy denies the creation of a Data Factory linked service that stores secrets (such as passwords and keys) as part of a connection string.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Data Factory",
        "name": "DataFactoryLinkedServicesDontStoreSecretsConString",
        "severity": 3,
        "controlId": "drcp-adf-04",
        "controlDesc": "Restrict the exposure of credential and secrets",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Data+Factory",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Data+Factory#IncidentremediationDataFactory-drcp-adf-04"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.DataFactory/factories/linkedservices"
          },
          {
            "anyOf": [
              {
                "allOf": [
                  {
                    "field": "Microsoft.DataFactory/factories/linkedservices/typeProperties.connectionString",
                    "exists": "true"
                  },
                  {
                    "anyOf": [
                      {
                        "field": "Microsoft.DataFactory/factories/linkedservices/typeProperties.connectionString",
                        "contains": "AccountKey="
                      },
                      {
                        "field": "Microsoft.DataFactory/factories/linkedservices/typeProperties.connectionString",
                        "contains": "CredString="
                      },
                      {
                        "field": "Microsoft.DataFactory/factories/linkedservices/typeProperties.connectionString",
                        "contains": "PWD="
                      },
                      {
                        "field": "Microsoft.DataFactory/factories/linkedservices/typeProperties.connectionString",
                        "contains": "pwd="
                      },
                      {
                        "field": "Microsoft.DataFactory/factories/linkedservices/typeProperties.connectionString",
                        "contains": "Password="
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

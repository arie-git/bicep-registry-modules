{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-sub-07 - Cross subscription private links'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription#drcp-sub-07 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP App Configuration Network Inbound Private endpoints private link service connections",
    "description": "This policy prevents inbound private link(s) between external subscriptions and App Configuration instances.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "App Configuration",
        "name": "AppConfigPEPLServiceConnections_Inbound",
        "severity": 3,
        "controlId": "drcp-sub-07",
        "controlDesc": "Cross Subscription private links",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Subscription",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#Incidentremediation+Subscription-drcp-sub-07"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Deny, Audit, or Disabled."
        },
        "allowedValues": [
          "Deny",
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "allowedInboundPrivateLinkServices": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed external subscriptions",
          "description": "List of the subscription ids."
        },
        "defaultValue": [
          "subscription().subscriptionId"
        ]
      }
    },
    "policyRule": {
      "if": {
        "anyOf": [
          {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.AppConfiguration/configurationStores/privateEndpointConnections"
              },
              {
                "field": "Microsoft.AppConfiguration/configurationStores/privateEndpointConnections/privateLinkServiceConnectionState.status",
                "equals": "Approved"
              },
              {
                "anyOf": [
                  {
                    "field": "Microsoft.AppConfiguration/configurationStores/privateEndpointConnections/privateEndpoint.id",
                    "exists": false
                  },
                  {
                    "value": "[split(concat(field('Microsoft.AppConfiguration/configurationStores/privateEndpointConnections/privateEndpoint.id'), '//'), '/')[2]]",
                    "notIn": "[parameters('allowedInboundPrivateLinkServices')]"
                  }
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-sub-16 - Load Balancer Private IP only in frontend'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription#drcp-sub-16"
  },
  "policyDefinition": {
    "displayName": "APG DRCP Load Balancer Private IP Only in Frontend",
    "description": "This policy enforces private IP addresses only in frontend configuration of load balancers.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Subscription",
        "name": "NetworkLoadBalancerPrivateIPFrontendEnabled",
        "severity": 3,
        "controlId": "drcp-sub-16",
        "controlDesc": "Load balancer frontend configuration",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Subscription",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription-drcp-sub-16"
      }
    },
    "mode": "Indexed",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Deny, Disabled or Audit."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Network/loadBalancers"
          },
          {
            "anyOf": [
              {
                "exists": false,
                "field": "Microsoft.Network/loadBalancers/frontendIPConfigurations[*].subnet"
              },
              {
                "exists": true,
                "field": "Microsoft.Network/loadBalancers/frontendIPConfigurations[*].publicIPAddress"
              },
              {
                "exists": true,
                "field": "Microsoft.Network/loadBalancers/frontendIPConfigurations[*].publicIPPrefix"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
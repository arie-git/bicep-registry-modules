{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-amg-03 - Disable Grafana Enterprise'. For more information, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Azure+Monitor#IncidentremediationAzureMonitor-drcp-amg-03 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Azure Monitor Managed Grafana Disable Enterprise upgrade",
    "description": "This policy ensures that Managed Grafana does not use the Enterprise upgrade.",
    "mode": "Indexed",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Monitor",
        "name": "MonitorManagedGrafanaDisableEnterprise",
        "severity": 3,
        "controlId": "drcp-amg-03",
        "controlDesc": "Disable Grafana Enterprise.",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Azure+Monitor",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Azure+Monitor#IncidentremediationAzureMonitor-drcp-amg-03"
      }
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Dashboard/grafana"
          },
          {
            "field": "Microsoft.Dashboard/grafana/enterpriseConfigurations",
            "exists": true
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-ai-03' - Use of private DNS zones for private endpoints'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+AI+services#IncidentremediationAIservices#drcp-ai-03 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP AI services Network Private DNS zones account",
    "description": "This policy automatically remediates the Private DNS Group for account private endpoints.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "dynamic": "true",
      "drcp": {
        "component": "AI services",
        "name": "AIServicesPrivateDNSZones",
        "severity": 3,
        "controlId": "drcp-ai-03",
        "controlDesc": "Use of private DNS zones for private endpoints",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+AI+services",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+AI+services#IncidentremediationAIservices#drcp-ai-03"
      }
    },
    "mode": "Indexed",
    "parameters": {
      "defaultPrivateDnsZoneId": {
        "type": "String",
        "metadata": {
          "displayName": "Default Private DNS Zone ID",
          "description": "The default Private DNS Zone ID for AI services resources (except Azure OpenAI).",
          "strongType": "Microsoft.Network/privateDnsZones"
        }
      },
      "azureOpenAIPrivateDnsZoneId": {
        "type": "String",
        "metadata": {
          "displayName": "Azure OpenAI Private DNS Zone ID",
          "description": "The Private DNS Zone ID for Azure OpenAI resources.",
          "strongType": "Microsoft.Network/privateDnsZones"
        }
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - DeployIfNotExists or Disabled."
        },
        "allowedValues": [
          "DeployIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Network/privateEndpoints"
          },
          {
            "count": {
              "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*]",
              "where": {
                "allOf": [
                  {
                    "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].privateLinkServiceId",
                    "contains": "Microsoft.CognitiveServices"
                  },
                  {
                    "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].groupIds[*]",
                    "equals": "account"
                  }
                ]
              }
            },
            "greaterOrEquals": 1
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
          "evaluationDelay": "AfterProvisioning",
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/acdd72a7-3385-48ef-bd42-f606fba81ae7"
          ],
          "deployment": {
            "properties": {
              "mode": "incremental",
              "template": {
                "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                "contentVersion": "1.0.0.0",
                "parameters": {
                  "defaultPrivateDnsZoneId": {
                    "type": "string"
                  },
                  "azureOpenAIPrivateDnsZoneId": {
                    "type": "string"
                  },
                  "privateEndpointName": {
                    "type": "string"
                  },
                  "location": {
                    "type": "string"
                  },
                  "privateLinkServiceId": {
                    "type": "array"
                  }
                },
                "resources": [
                  {
                    "name": "[concat(parameters('privateEndpointName'), '/deployedByPolicy')]",
                    "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
                    "apiVersion": "2020-03-01",
                    "location": "[parameters('location')]",
                    "properties": {
                      "privateDnsZoneConfigs": [
                        {
                          "name": "searchService-privateDnsZone",
                          "properties": {
                            "privateDnsZoneId": "[if(equals(reference(parameters('privateLinkServiceId')[0], '2022-12-01', 'Full').kind, 'OpenAI'), parameters('azureOpenAIPrivateDnsZoneId'), parameters('defaultPrivateDnsZoneId'))]"
                          }
                        }
                      ]
                    }
                  }
                ]
              },
              "parameters": {
                "defaultPrivateDnsZoneId": {
                  "value": "[parameters('defaultPrivateDnsZoneId')]"
                },
                "azureOpenAIPrivateDnsZoneId": {
                  "value": "[parameters('azureOpenAIPrivateDnsZoneId')]"
                },
                "privateEndpointName": {
                  "value": "[field('name')]"
                },
                "location": {
                  "value": "[field('location')]"
                },
                "privateLinkServiceId": {
                  "value": "[field('Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].privateLinkServiceId')]"
                }
              }
            }
          }
        }
      }
    }
  }
}
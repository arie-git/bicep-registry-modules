{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-aps-01 - Deny public network access'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+App+Service#IncidentremediationAppService#drcp-aps-01 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP App Service Static Sites Public network access",
    "description": "This policy prevents the creation of a static site app service that has public network access enabled.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "App Service",
        "name": "AppServiceStaticSitesPublicNetworkAccessEnabled",
        "severity": 3,
        "controlId": "drcp-aps-01",
        "controlDesc": "Disable public network access",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+App+Service",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+App+Service#IncidentremediationAppService-drcp-aps-01"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/staticSites"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Web/staticSites/publicNetworkAccess",
                "exists": "false"
              },
              {
                "field": "Microsoft.Web/staticSites/publicNetworkAccess",
                "notEquals": "Disabled"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

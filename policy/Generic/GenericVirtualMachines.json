{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-sub-18 - Resource type restriction'. Virtual machine(set)s are not allowed. For more information, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription-drcp-sub-18 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP IAAS Creation of virtual machine(set)s",
    "description": "This policy prevents users from creating a virtual machine or virtual machine sets outside the managed resource group.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Subscription",
        "name": "GenericVirtualMachines",
        "severity": 3,
        "controlId": "drcp-sub-18",
        "controlDesc": "Resource type restriction",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Subscription",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription-drcp-sub-18"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Deny or Disabled."
        },
        "allowedValues": [
          "Deny",
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "contains": "Microsoft.Compute"
          },
          {
            "field": "type",
            "notContains": "Microsoft.Compute/disks"
          },
          {
            "not": {
              "anyOf": [
                {
                  "value": "[resourceGroup().name]",
                  "like": "AKS-Node*"
                },
                {
                  "value": "[resourceGroup().name]",
                  "like": "*-adbmanaged-rg"
                }
              ]
            }
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

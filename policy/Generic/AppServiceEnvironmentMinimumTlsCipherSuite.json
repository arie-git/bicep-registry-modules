{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-aps-14 - Deny weak TLS Cipher suites in App Service Environments'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+App+Service#IncidentremediationAppService#drcp-aps-14 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP App Service Environment Deny lower TLS cipher suite versions",
    "description": "This policy requires App Service Environments to use a recent TLS cipher suite version.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "App Service",
        "name": "AppServiceEnvironmentMinimumTlsCipherSuite",
        "severity": 3,
        "controlId": "drcp-aps-14",
        "controlDesc": "Deny weak TLS Cipher suites in App Service Environments",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+App+Service",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+App+Service#IncidentremediationAppService-drcp-aps-14"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "kind",
            "like": "ASE*"
          },
          {
            "field": "type",
            "equals": "Microsoft.Web/hostingEnvironments"
          },
          {
            "count": {
              "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*]",
              "where": {
                "allOf": [
                  {
                    "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].name",
                    "contains": "FrontEndSSLCipherSuiteOrder"
                  },
                  {
                    "anyOf": [
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_AES_256_GCM_SHA384"
                      },
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_AES_128_GCM_SHA256"
                      },
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384"
                      },
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256"
                      },
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384"
                      },
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256"
                      },
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_ECDHE_ECDSA_WITH_AES_256_CCM"
                      },
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_ECDHE_ECDSA_WITH_AES_128_CCM"
                      },
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_CHACHA20_POLY1305_SHA256"
                      },
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305_SHA256"
                      },
                      {
                        "field": "Microsoft.Web/HostingEnvironments/clusterSettings[*].value",
                        "contains": "TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305_SHA256"
                      }
                    ]
                  }
                ]
              }
            },
            "less": 1
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

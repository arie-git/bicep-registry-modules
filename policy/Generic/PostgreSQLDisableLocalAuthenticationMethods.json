{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-psql-02 - Disabled local authentication methods'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+PostgreSQL#IncidentremediationPostgreSQL#drcp-psql-02 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP PostgreSQL Disable local authentication methods",
    "mode": "All",
    "description": "This policy disables local authentication methods and ensures PostgreSQL access is restricted to Microsoft Entra ID authentication.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "PostgreSQL",
        "name": "PostgreSQLDisableLocalAuthenticationMethods",
        "severity": 3,
        "controlId": "drcp-psql-02",
        "controlDesc": "Microsoft Entra ID authentication",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+PostgreSQL",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+PostgreSQL#IncidentremediationPostgreSQL#drcp-psql-02"
      },
      "dynamic": "true"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Disabled or Deny."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.DBForPostgreSql/flexibleServers"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.DBForPostgreSql/flexibleServers/authConfig.activeDirectoryAuth",
                "notEquals": "Enabled"
              },
              {
                "field": "Microsoft.DBForPostgreSql/flexibleServers/authConfig.passwordAuth",
                "notEquals": "Disabled"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
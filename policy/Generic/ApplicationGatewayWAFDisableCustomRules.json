{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-agw-07 - Custom rules and exclusions'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Application+Gateway#IncidentremediationApplicationGateway#drcp-agw-07 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Application Gateway Web Application Firewall should not contain custom rules other than rule type rate limit",
    "description": "This policy enforces that there are no custom rules other than rule type rate limit configured for the Web Application Firewall (WAF) functionality on the Application Gateway.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Application Gateway",
        "name": "ApplicationGatewayWAFDisableCustomRules",
        "severity": 3,
        "controlId": "drcp-agw-07",
        "controlDesc": "Custom rules and exclusions",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Application+Gateway+Web+Application+Firewall",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Application+Gateway#IncidentremediationApplicationGateway-drcp-agw-07"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Deny, Audit or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "count": {
              "field": "Microsoft.Network/applicationGatewayWebApplicationFirewallPolicies/customRules[*]"
            },
            "greater": 0
          },
          {
            "count": {
              "field": "Microsoft.Network/applicationGatewayWebApplicationFirewallPolicies/customRules[*]",
              "where": {
                "field": "Microsoft.Network/applicationGatewayWebApplicationFirewallPolicies/customRules[*].ruleType",
                "notEquals": "RateLimitRule"
              }
            },
            "greater": 0
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-sql-01 - Disable Public Network Access'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+SQL+Database#IncidentremediationSQLDatabase#drcp-sql-01 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP SQL Server Restrict outbound network access",
    "mode": "All",
    "description": "This policy audits if 'restrict outbound network access' is enabled on SQL Servers.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "SQL Database",
        "name": "SQLServerRestrictOutboundNetworkAccess",
        "severity": 3,
        "controlId": "drcp-sql-01",
        "controlDesc": "Disable public network access",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+SQL+Database",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+SQL+Database#IncidentremediationSQLDatabase-drcp-sql-01"
      }
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Sql/servers"
          },
          {
            "field": "Microsoft.Sql/servers/restrictOutboundNetworkAccess",
            "notEquals": "Enabled"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

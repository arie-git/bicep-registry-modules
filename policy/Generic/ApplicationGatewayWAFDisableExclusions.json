{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-agw-07 - Custom rules and exclusions'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Application+Gateway#IncidentremediationApplicationGateway#drcp-agw-07 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Application Gateway Web Application Firewall should not contain exclusions on managed rules",
    "description": "This policy enforces that there are no managed rules exclusions configured for the Web Application Firewall (WAF) functionality on the Application Gateway.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Application Gateway",
        "name": "ApplicationGatewayWAFDisableExclusions",
        "severity": 3,
        "controlId": "drcp-agw-07",
        "controlDesc": "Custom rules and exclusions",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Application+Gateway+Web+Application+Firewall",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Application+Gateway#IncidentremediationApplicationGateway-drcp-agw-07"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Deny, Audit or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "allowedExcludedRuleIds": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed WAF rules exclusions",
          "description": "List of WAF rules which are allowed to be excluded."
        },
        "defaultValue": []
      }
    },
    "policyRule": {
      "if": {
        "anyOf": [
          {
            "allOf": [
              {
                "field": "Microsoft.Network/applicationGatewayWebApplicationFirewallPolicies/managedRules.exclusions[*]",
                "exists": true
              },
              {
                "count": {
                  "field": "Microsoft.Network/applicationGatewayWebApplicationFirewallPolicies/managedRules.exclusions[*].exclusionManagedRuleSets[*].ruleGroups[*].rules[*]",
                  "where": {
                    "field": "Microsoft.Network/ApplicationGatewayWebApplicationFirewallPolicies/managedRules.exclusions[*].exclusionManagedRuleSets[*].ruleGroups[*].rules[*].ruleId",
                    "notIn": "[parameters('allowedExcludedRuleIds')]"
                  }
                },
                "greater": 0
              }
            ]
          },
          {
            "count": {
              "field": "Microsoft.Network/applicationGatewayWebApplicationFirewallPolicies/managedRules.exclusions[*]",
              "where": {
                "count": {
                  "field": "Microsoft.Network/applicationGatewayWebApplicationFirewallPolicies/managedRules.exclusions[*].exclusionManagedRuleSets[*]"
                },
                "equals": 0
              }
            },
            "greater": 0
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

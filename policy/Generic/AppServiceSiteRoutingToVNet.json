{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-aps-10 - Audit for enabling outbound non-RFC 1918 traffic to Azure Virtual Network'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+App+Service#IncidentremediationAppService#drcp-aps-10 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP App Service Site routing to Azure Virtual Network",
    "description": "This policy enforces image pulling and content share traffic to be directed through the Azure Virtual Network. By default, app configuration such as pulling container images and mounting content storage will not be routed through the regional virtual network integration. These settings allow features like network security groups and user defined routes to be used, and service endpoints to be private. For more information, visit https://aka.ms/appservice-vnet-configuration-routing.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "App Service",
        "name": "AppServiceSiteRoutingToVNet",
        "severity": 3,
        "controlId": "drcp-aps-10",
        "controlDesc": "Audit for enabling outbound non-RFC 1918 traffic to Azure Virtual Network",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+App+Service",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+App+Service#IncidentremediationAppService-drcp-aps-10"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites"
          },
          {
            "anyOf": [
              {
                "allOf": [
                  {
                    "field": "Microsoft.Web/sites/vnetImagePullEnabled",
                    "exists": "true"
                  },
                  {
                    "field": "Microsoft.Web/sites/vnetImagePullEnabled",
                    "notEquals": "true"
                  }
                ]
              },
              {
                "allOf": [
                  {
                    "field": "Microsoft.Web/sites/vnetContentShareEnabled",
                    "exists": "true"
                  },
                  {
                    "field": "Microsoft.Web/sites/vnetContentShareEnabled",
                    "notEquals": "true"
                  }
                ]
              },
              {
                "allOf": [
                  {
                    "field": "Microsoft.Web/sites/outboundVnetRouting.imagePullTraffic",
                    "exists": "true"
                  },
                  {
                    "field": "Microsoft.Web/sites/outboundVnetRouting.imagePullTraffic",
                    "notEquals": "true"
                  }
                ]
              },
              {
                "allOf": [
                  {
                    "field": "Microsoft.Web/sites/outboundVnetRouting.contentShareTraffic",
                    "exists": "true"
                  },
                  {
                    "field": "Microsoft.Web/sites/outboundVnetRouting.contentShareTraffic",
                    "notEquals": "true"
                  }
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

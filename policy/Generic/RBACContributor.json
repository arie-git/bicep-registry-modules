{
  "policyMetadata": {
    "noncomplianceMessage": "The Contributor RBAC role is only allowed to be assigned to a given set of principals. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Role+Based+Access+Control+policies ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP RBAC Contributor role",
    "description": "This policy ensures that the Contributor role cannot be assigned.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Subscription",
        "name": "RBACContributor",
        "severity": 3,
        "controlId": "drcp-sub-11",
        "controlDesc": "Role Based Access Control",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Subscription",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription-drcp-sub-11"
      }
    },
    "mode": "All",
    "parameters": {
      "roleDefinitionId": {
        "type": "String",
        "metadata": {
          "description": "Role Definition Id of Contributor Role.",
          "displayName": "Role Definition Id of Contributor Role"
        },
        "defaultValue": "b24988ac-6180-42a0-ab88-20f7382dd24c"
      },
      "allowedPrincipalIds": {
        "type": "Array",
        "metadata": {
          "description": "Allowed AAD principal Ids. By default, no service principals are allowed to use the Contributor role.",
          "displayName": "Allowed AAD principal Ids"
        },
        "defaultValue": []
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Authorization/roleAssignments"
          },
          {
            "field": "Microsoft.Authorization/roleAssignments/roleDefinitionId",
            "contains": "[parameters('roleDefinitionId')]"
          },
          {
            "field": "Microsoft.Authorization/roleAssignments/principalId",
            "notIn": "[parameters('allowedPrincipalIds')]"
          },
          {
            "not": {
              "value": "[resourceGroup().name]",
              "like": "AKS-Node*"
            }
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

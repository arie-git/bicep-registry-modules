{
  "policyMetadata": {
    "noncomplianceMessage": "The DRCP contributor roles are only allowed to be assigned to the allowed groups and principals. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Role+Based+Access+Control+policies ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Contributor role targets",
    "description": "This policy ensures that the DRCP contributor role is only able to be assigned to the allowed groups and principals.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Subscription",
        "name": "RBACAllowedDRCPContributorTargets",
        "severity": 3,
        "controlId": "drcp-sub-11",
        "controlDesc": "Role Based Access Control",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Subscription",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription-drcp-sub-11"
      }
    },
    "mode": "All",
    "parameters": {
      "DRCPContributorIds": {
        "type": "String",
        "metadata": {
          "description": "Guids of the DRCP contributor roles.",
          "displayName": "Guids of the DRCP contributor roles for all usages."
        }
      },
      "allowedPrincipalIds": {
        "type": "Array",
        "metadata": {
          "description": "Allowed Entra principal and group Ids.",
          "displayName": "Allowed Entra principal and group Ids"
        },
        "defaultValue": []
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Authorization/roleAssignments"
          },
          {
            "value": "[last(split(field('Microsoft.Authorization/roleAssignments/roleDefinitionId'), '/'))]",
            "in": "[split(parameters('DRCPContributorIds'),';')]"
          },
          {
            "field": "Microsoft.Authorization/roleAssignments/principalId",
            "notIn": "[parameters('allowedPrincipalIds')]"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-st-06 - Encrypt sensitive data in transit'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Storage+Account#IncidentremediationStorageAccount#drcp-st-06 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP StorageAccount Minimum TLS version",
    "description": "This policy denies older TLS versions than prescribed by APG on Azure Storage Account resources.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Storage Account",
        "name": "StorageAccountMinimumTlsVersion",
        "severity": 3,
        "controlId": "drcp-st-06",
        "controlDesc": "Encrypt sensitive data in transit",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Storage+Account",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Storage+Account#IncidentremediationStorageAccount-drcp-st-06"
      }
    },
    "mode": "All",
    "parameters": {
      "minimumTlsVersion": {
        "type": "String",
        "metadata": {
          "displayName": "Required TLS Version",
          "description": "The TLS version that should be configured on the Storage Account"
        },
        "allowedValues": [
          "TLS1_2",
          "TLS1_3"
        ],
        "defaultValue": "TLS1_2"
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Deny or Disabled."
        },
        "allowedValues": [
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Storage/storageAccounts"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Storage/storageAccounts/minimumTlsVersion",
                "exists": false
              },
              {
                "field": "Microsoft.Storage/storageAccounts/minimumTlsVersion",
                "less": "[parameters('minimumTlsVersion')]"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

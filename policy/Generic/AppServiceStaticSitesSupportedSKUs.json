{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-aps-01 - Deny public network access'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+App+Service#IncidentremediationAppService#drcp-aps-01 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP App Service Static Sites SKU that supports private links",
    "description": "This policy prevents the creation of an app service static site that uses a SKU that doesn't support private links.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "App Service",
        "name": "AppServiceStaticSitesSupportedSKUs",
        "severity": 3,
        "controlId": "drcp-aps-01",
        "controlDesc": "Disable public network access",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+App+Service",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+App+Service#IncidentremediationAppService-drcp-aps-01"
      }
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "listOfSkuTiers": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed SKU tiers",
          "description": "The list of allowed static App Service SKU tiers."
        },
        "allowedValues": [
          "Standard"
        ],
        "defaultValue": [
          "Standard"
        ]
      },
      "listOfSkuNames": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed SKU names",
          "description": "The list of allowed static App Service SKU names."
        },
        "allowedValues": [
          "S1"
        ],
        "defaultValue": [
          "S1"
        ]
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/staticSites"
          },
          {
            "allOf": [
              {
                "field": "Microsoft.Web/staticSites/sku.tier",
                "notIn": "[parameters('listOfSkuTiers')]"
              },
              {
                "field": "Microsoft.Web/staticSites/sku.name",
                "notIn": "[parameters('listOfSkuNames')]"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

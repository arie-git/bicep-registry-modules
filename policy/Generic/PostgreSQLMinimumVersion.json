{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-psql-06 - Enforce minimum version of PostgreSQL'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+PostgreSQL#IncidentremediationPostgreSQL#drcp-psql-06 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP PostgreSQL Flexible servers should be running a minimum version",
    "mode": "All",
    "description": "This policy ensures PostgreSQL is running a supported version.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "PostgreSQL",
        "name": "PostgreSQLMinimumVersion",
        "severity": 3,
        "controlId": "drcp-psql-06",
        "controlDesc": "Enforce minimum version of PostgreSQL",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+PostgreSQL",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+PostgreSQL#IncidentremediationPostgreSQL#drcp-psql-06"
      }
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Disabled or Deny."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.DBForPostgreSql/flexibleServers"
          },
          {
            "field": "Microsoft.DBForPostgreSql/flexibleServers/version",
            "less": "16"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
{
  "policyMetadata": {
    "noncomplianceMessage": "The Security Manager RBAC role is only allowed to be assigned to a given set of principals.For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Role+Based+Access+Control+policies ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP RBAC Security Manager role",
    "description": "This policy ensures that the Security Manager RBAC role is only assigned to a given set of principals.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Subscription",
        "name": "RBACSecurityManager",
        "severity": 3,
        "controlId": "drcp-sub-11",
        "controlDesc": "Role Based Access Control",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Subscription",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription-drcp-sub-11"
      }
    },
    "mode": "All",
    "parameters": {
      "roleDefinitionId": {
        "type": "String",
        "metadata": {
          "description": "Role Definition Id of Security Manager Role.",
          "displayName": "Role Definition Id of Security Manager Role"
        },
        "defaultValue": "e3d13bf0-dd5a-482e-ba6b-9b8433878d10"
      },
      "allowedPrincipalIds": {
        "type": "Array",
        "metadata": {
          "description": "Allowed AAD principal Ids.",
          "displayName": "Allowed AAD principal Ids"
        },
        "defaultValue": []
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Audit, Deny or Disabled."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "anyOf": [
          {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Authorization/roleAssignments"
              },
              {
                "field": "Microsoft.Authorization/roleAssignments/roleDefinitionId",
                "contains": "[parameters('roleDefinitionId')]"
              },
              {
                "field": "Microsoft.Authorization/roleAssignments/principalId",
                "notIn": "[parameters('allowedPrincipalIds')]"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

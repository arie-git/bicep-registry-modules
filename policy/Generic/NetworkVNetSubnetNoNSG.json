{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-sub-06 - VNet subnet NSG'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription#drcp-sub-06 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Network VNet subnet NSG",
    "description": "This policy denies creation of subnets without an NSG.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Subscription",
        "name": "NetworkVNetSubnetNoNSG",
        "severity": 3,
        "controlId": "drcp-sub-06",
        "controlDesc": "VNet subnet NSG",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Subscription",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription-drcp-sub-06"
      },
      "dynamic": "true"
    },
    "mode": "All",
    "parameters": {
      "listOfNSGExceptions": {
        "type": "Array",
        "metadata": {
          "displayName": "Subnets with NSG exception",
          "description": "The list of subnets allow without Network Security Groups."
        },
        "allowedValues": [
          "GatewaySubnet",
          "AzureFirewallSubnet",
          "AzureFirewallManagementSubnet"
        ],
        "defaultValue": [
          "GatewaySubnet",
          "AzureFirewallSubnet",
          "AzureFirewallManagementSubnet"
        ]
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - Deny or Disabled."
        },
        "allowedValues": [
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "anyOf": [
          {
            "allOf": [
              {
                "equals": "Microsoft.Network/virtualNetworks/subnets",
                "field": "type"
              },
              {
                "exists": "false",
                "field": "Microsoft.Network/virtualNetworks/subnets/networkSecurityGroup.id"
              },
              {
                "field": "name",
                "notIn": "[parameters('listOfNSGExceptions')]"
              },
              {
                "value": "[length(field('Microsoft.Network/virtualNetworks/subnets/privateEndpoints[*]'))]",
                "equals": 0
              }
            ]
          },
          {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Network/virtualNetworks"
              },
              {
                "count": {
                  "field": "Microsoft.Network/virtualNetworks/subnets[*]",
                  "where": {
                    "allOf": [
                      {
                        "field": "Microsoft.Network/virtualNetworks/subnets[*].networkSecurityGroup.id",
                        "exists": "false"
                      },
                      {
                        "field": "Microsoft.Network/virtualNetworks/subnets[*].name",
                        "notIn": "[parameters('listOfNSGExceptions')]"
                      },
                      {
                        "value": "[length(field('Microsoft.Network/virtualNetworks/subnets[*].privateEndpoints[*]'))]",
                        "equals": 0
                      }
                    ]
                  }
                },
                "notEquals": 0
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}

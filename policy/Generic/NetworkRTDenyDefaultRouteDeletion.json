{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-sub-02 - Default network route'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription#drcp-sub-02 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP Network Deny deletion of the default route to Virtual Appliance",
    "description": "DRCP - Prevents deletion of the default route with address prefix 0.0.0.0/0 pointing to the virtual appliance.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "Subscription",
        "name": "NetworkRTDenyDefaultRouteDeletion",
        "severity": 3,
        "controlId": "drcp-sub-02",
        "controlDesc": "Default network route",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+Subscription",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription-drcp-sub-02"
      },
      "dynamic": "true"
    },
    "mode": "All",
    "parameters": {
      "virtualApplianceIpAddress": {
        "type": "String",
        "metadata": {
          "displayName": "NVA IP",
          "description": "IP address of the NVA."
        },
        "defaultValue": "10.250.4.254"
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - DenyAction or Disabled."
        },
        "allowedValues": [
          "DenyAction",
          "Disabled"
        ],
        "defaultValue": "DenyAction"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Network/routeTables/routes"
          },
          {
            "not": {
              "value": "[resourceGroup().name]",
              "like": "*-agw-rg"
            }
          },
          {
            "field": "Microsoft.Network/routeTables/routes/addressPrefix",
            "equals": "0.0.0.0/0"
          },
          {
            "field": "Microsoft.Network/routeTables/routes/nextHopType",
            "equals": "VirtualAppliance"
          },
          {
            "field": "Microsoft.Network/routeTables/routes/nextHopIpAddress",
            "equals": "[parameters('virtualApplianceIpAddress')]"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "actionNames": [
            "delete"
          ]
        }
      }
    }
  }
}

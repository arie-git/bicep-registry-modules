{
  "policyMetadata": {
    "noncomplianceMessage": "DRCP control 'drcp-sub-08 - Automated private link DNS integration'. For remediation, see https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription#drcp-sub-08 ."
  },
  "policyDefinition": {
    "displayName": "APG DRCP App Service Static Sites Private DNS zones",
    "description": "This policy automatically remediates the private DNS zone group for Static Web App private endpoints.",
    "metadata": {
      "category": "APG DRCP Policy",
      "status": "active",
      "drcp": {
        "component": "App Service",
        "name": "AppServiceStaticSitesPartitionedPrivateDNSZones",
        "severity": 3,
        "controlId": "drcp-sub-08",
        "controlDesc": "Audit for injection of App Service apps into a virtual network",
        "baselineUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Security+baseline+App+Service",
        "remediationUrl": "https://confluence.office01.internalcorp.net:8453/display/DRCPKB/Incident+remediation+Subscription#IncidentremediationSubscription#drcp-sub-08"
      },
      "dynamic": "true"
    },
    "mode": "Indexed",
    "parameters": {
      "privateDnsZoneId": {
        "type": "String",
        "metadata": {
          "displayName": "privateDnsZoneId",
          "strongType": "Microsoft.Network/privateDnsZones"
        }
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect of this Azure Policy - DeployIfNotExists or Disabled."
        },
        "allowedValues": [
          "DeployIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Network/privateEndpoints"
          },
          {
            "count": {
              "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*]",
              "where": {
                "allOf": [
                  {
                    "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].privateLinkServiceId",
                    "contains": "Microsoft.Web/staticSites"
                  },
                  {
                    "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].groupIds[*]",
                    "equals": "staticSites"
                  }
                ]
              }
            },
            "greaterOrEquals": 1
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
          "evaluationDelay": "AfterProvisioning",
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/acdd72a7-3385-48ef-bd42-f606fba81ae7"
          ],
          "deployment": {
            "properties": {
              "mode": "incremental",
              "template": {
                "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                "contentVersion": "1.0.0.0",
                "parameters": {
                  "privateDnsZoneId": {
                    "type": "string"
                  },
                  "privateEndpointName": {
                    "type": "string"
                  },
                  "privateLinkServiceId": {
                    "type": "array"
                  }
                },
                "resources": [
                  {
                    "apiVersion": "2023-04-01",
                    "location": "[resourceGroup().location]",
                    "name": "[concat(parameters('privateEndpointName'), '/deployedByPolicy')]",
                    "properties": {
                      "privateDnsZoneConfigs": [
                        {
                          "name": "staticWebApp-privateDnsZone",
                          "properties": {
                            "privateDnsZoneId": "[if(greaterOrEquals(length(split(reference(parameters('privateLinkServiceId')[0], '2023-12-01').defaultHostname, '.')), 4), replace(parameters('privateDnsZoneId'),'azurestaticapps.net', concat(split(reference(parameters('privateLinkServiceId')[0], '2023-12-01').defaultHostname, '.')[1],'.azurestaticapps.net')), parameters('privateDnsZoneId'))]"
                          }
                        }
                      ]
                    },
                    "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups"
                  }
                ]
              },
              "parameters": {
                "privateDnsZoneId": {
                  "value": "[parameters('privateDnsZoneId')]"
                },
                "privateEndpointName": {
                  "value": "[field('name')]"
                },
                "privateLinkServiceId": {
                  "value": "[field('Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].privateLinkServiceId')]"
                }
              }
            }
          }
        }
      }
    }
  }
}

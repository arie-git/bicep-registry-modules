{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Agent",

      "Edit(tasks/**)",
      "Write(tasks/**)",

      "Edit(amavm/verified-modules/**)",
      "Write(amavm/verified-modules/**)",

      "Edit(/home/node/.claude/**)",
      "Write(/home/node/.claude/**)",

      "Bash(bicep build *)",
      "Bash(bicep lint *)",
      "Bash(az bicep build *)",
      "Bash(az bicep lint *)",

      "Bash(pwsh *)",

      "Bash(python3 *)",

      "Bash(ls *)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(grep *)",
      "Bash(echo *)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git log *)",
      "Bash(git add **)",
      "Bash(git commit *)",
      "Bash(mkdir -p **)",

      "Read(/tmp/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)"

    ],
    "deny": [
      "Edit(microsoft-avm/**)",
      "Write(microsoft-avm/**)",
      "Edit(policy/Generic/**)",
      "Write(policy/Generic/**)",
      "Edit(amavm/pipelines/**)",
      "Write(amavm/pipelines/**)",

      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git reset *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  }
}

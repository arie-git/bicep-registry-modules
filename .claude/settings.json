{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Agent",

      "Edit(tasks/*.md)",
      "Write(tasks/*.md)",

      "Edit(amavm/verified-modules/**/*.bicep)",
      "Edit(amavm/verified-modules/**/*.md)",
      "Write(amavm/verified-modules/**/*.bicep)",
      "Write(amavm/verified-modules/**/*.md)",
      "Write(amavm/verified-modules/**/upstream.json)",
      "Write(amavm/verified-modules/**/version.json)",

      "Bash(bicep build *)",
      "Bash(bicep lint *)",
      "Bash(az bicep build *)",
      "Bash(az bicep lint *)",

      "Bash(pwsh -Command *)",
      "Bash(pwsh -File *)",
      "Bash(pwsh -c *)",

      "Bash(cd /workspaces/bicep-registry-modules/amavm/verified-modules && pwsh *)",

      "Bash(ls *)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(cat *)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git log *)",
      "Bash(git add amavm/verified-modules/*)",
      "Bash(git add tasks/*)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Edit(microsoft-avm/**)",
      "Write(microsoft-avm/**)",
      "Edit(policy/**)",
      "Write(policy/**)",
      "Edit(amavm/pipelines/**)",
      "Write(amavm/pipelines/**)",
      "Edit(amavm/utils/**)",
      "Write(amavm/utils/**)",

      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git reset *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  }
}
